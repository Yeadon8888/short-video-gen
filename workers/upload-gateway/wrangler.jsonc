{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vidclaw-upload-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-12",
  "workers_dev": true,
  "vars": {
    "UPLOAD_PREFIX": "vidclaw-assets",
    "MAX_UPLOAD_BYTES": "104857600"
  },
  "routes": [
    { "pattern": "vc-upload.yeadon.top", "custom_domain": true }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS_BUCKET",
      "bucket_name": "vidclaw-assets"
    }
  ]
}
