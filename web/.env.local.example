# 鉴权
# 格式: CODE1:Name1,CODE2:Name2
INVITE_CODES=ABC123:Alice,DEF456:Bob
# 随机32字节十六进制字符串: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_32_byte_hex_secret_here

# API Keys
YUNWU_API_KEY=sk-...
YUNWU_GEMINI_API_KEY=sk-...   # 可选，默认回退到 YUNWU_API_KEY
YUNWU_API_KEY2=sk-...         # Sora fallback，可选，默认回退到 YUNWU_API_KEY

# Cloudflare R2 (产品图存储，可选)
R2_ACCOUNT_ID=
R2_BUCKET=
R2_PUBLIC_DOMAIN=
S3_ID=
S3_token=
