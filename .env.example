# 云雾 API Key（Sora 视频生成，必填）
YUNWU_API_KEY=your_yunwu_api_key_here

# 云雾 Gemini API Key（视频理解，不填则回退到 YUNWU_API_KEY）
YUNWU_GEMINI_API_KEY=your_yunwu_gemini_api_key_here

# Cloudflare R2 产品图片存储（可选，不填则跳过图片上传）
R2_ACCOUNT_ID=your_r2_account_id
R2_BUCKET=your_bucket_name
R2_PUBLIC_DOMAIN=your_public_domain
S3_ID=your_s3_access_key_id
S3_token=your_s3_secret_access_key
